{
  "compilerOptions": {
    "target": "ESNext",
    "module": "esnext",
    "allowJs": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": "./",
    "paths": {
      "@/*": ["src/*"],
      "@core/*": ["src/core/*"],
      "@aurora/*": ["src/core/aurora/*"],
      "@sandbox/*": ["src/sandbox/*"]
    },
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "types": ["@webgpu/types"]
  }
}
